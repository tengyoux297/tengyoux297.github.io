---
layout: default
---
{% assign cv_link = site.cv_pdf_link | default: site.data.socials.cv_pdf | default: '/assets/pdf/cv.pdf' %}
{% assign scholar_userid = site.data.socials.scholar_userid %}
{% assign school_email = site.data.socials.email %}
{% assign personal_gmail = 'tengyoux@gmail.com' %}
<div class="post research-home">
  <article>
    <header class="research-hero">
      <div class="research-hero-copy">
        {% if page.subtitle %}
          <p class="hero-kicker">{{ page.subtitle }}</p>
        {% endif %}
        <h1 class="post-title">
          <span class="font-weight-bold">{{ site.first_name }}</span>
          {% if site.middle_name %}
            {{ site.middle_name }}
          {% endif %}
          {{ site.last_name }}
        </h1>
        <div class="hero-lede">{{ content }}</div>
      </div>

      {% if page.profile %}
        <div class="research-hero-media">
          {% if page.profile.image %}
            {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
            {% if page.profile.image_circular %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
            {% else %}
              {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
            {% endif %}
            {% capture sizes %}(min-width: {{ site.max_width }}) 288px, (min-width: 768px) 30vw, 82vw{% endcapture %}
            <div class="hero-portrait">
              {%
                include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
                cache_bust=true
              %}
            </div>
          {% endif %}
          {% if page.profile.more_info %}
            <div class="hero-aside">{{ page.profile.more_info }}</div>
          {% endif %}
        </div>
      {% endif %}
    </header>

    <div class="home-sections">
      {% if page.announcements and page.announcements.enabled %}
        <section class="section-card">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Updates</p>
              <h2>Recent News</h2>
            </div>
          </div>
          {% include news.liquid limit=true %}
        </section>
      {% endif %}

      {% if page.selected_papers %}
        <section class="section-card section-card-feature">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Research</p>
              <h2>Selected Publications</h2>
            </div>
            <a class="section-link" href="{{ '/publications/' | relative_url }}">View all</a>
          </div>
          {% include selected_papers.liquid %}
        </section>
      {% endif %}

      {% if page.social %}
        <section class="section-card">
          <div class="section-heading">
            <div><p class="section-kicker">Contact</p></div>
          </div>
          <div class="social">
            <div class="contact-icons">
              {% if school_email %}
                <a href="mailto:{{ school_email | encode_email }}" aria-label="School email" title="School email">
                  <span class="school-email-mark" aria-hidden="true">
                    <i class="fa-solid fa-envelope school-email-base"></i>
                    <span class="school-email-badge">
                      <i class="fa-solid fa-circle school-email-badge-bg"></i>
                      <i class="fa-solid fa-graduation-cap school-email-badge-icon"></i>
                    </span>
                  </span>
                </a>
              {% endif %}
              <a href="mailto:{{ personal_gmail | encode_email }}" aria-label="Personal Gmail" title="Personal Gmail">
                <i class="fa-solid fa-envelope"></i>
              </a>
              {% if scholar_userid %}
                <a
                  href="https://scholar.google.com/citations?user={{ scholar_userid }}"
                  aria-label="Google Scholar"
                  title="Google Scholar"
                >
                  <i class="ai ai-google-scholar"></i>
                </a>
              {% endif %}
            </div>
            <div class="contact-note">{{ site.contact_note }}</div>
          </div>
        </section>
      {% endif %}
    </div>

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
